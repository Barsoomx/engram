{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "engram hook session-start --agent claude_code --response-format claude-code",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "engram hook post-tool-use --agent claude_code --response-format claude-code",
            "timeout": 120
          }
        ]
      }
    ],
    "Error": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "engram hook error --agent claude_code --response-format claude-code",
            "timeout": 60
          }
        ]
      }
    ],
    "Decision": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "engram hook decision --agent claude_code --response-format claude-code",
            "timeout": 60
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "engram hook session-end --agent claude_code --response-format claude-code",
            "timeout": 60
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "engram hook user-prompt-submit --agent claude_code --response-format claude-code",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
