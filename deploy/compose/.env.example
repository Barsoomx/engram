ENGRAM_SECRET_KEY=change-me-local-development-only
ENGRAM_DEBUG=false
ENGRAM_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
ENGRAM_LOG_LEVEL=INFO
ENGRAM_CELERY_BROKER_URL=amqp://engram:engram@rabbitmq:5672/engram
ENGRAM_CELERY_RESULT_BACKEND=redis://redis:6379/1
ENGRAM_BOOTSTRAP_ADMIN_USERNAME=admin
ENGRAM_BOOTSTRAP_ADMIN_PASSWORD=
ENGRAM_BOOTSTRAP_ORG_SLUG=default
ENGRAM_BOOTSTRAP_PROJECT_SLUG=default
ENGRAM_BOOTSTRAP_TEAM_SLUG=default
# Minutes of inactivity before an ACTIVE agent session is force-ended and distilled
ENGRAM_SESSION_IDLE_TIMEOUT_MINUTES=30
ENGRAM_PROVIDER_HTTP_TIMEOUT=60
ENGRAM_EMBEDDING_HTTP_TIMEOUT=30
ENGRAM_DISTILL_CHUNK_CHAR_BUDGET=40000
ENGRAM_DISTILL_MAX_CHUNKS=8
ENGRAM_DISTILL_REDUCE_TARGET=12
ENGRAM_DISTILL_SOFT_TIME_LIMIT=600
ENGRAM_DISTILL_TIME_LIMIT=660
