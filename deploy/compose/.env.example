# Leave empty for dev/test. MUST be a strong unique value for any non-dev ENGRAM_ENVIRONMENT;
# an empty or known-placeholder value is rejected outside dev/test.
ENGRAM_SECRET_KEY=
# dev|development|local|test are non-production. Any other value (e.g. production, staging)
# enforces ENGRAM_SECRET_KEY and ENGRAM_ALLOWED_HOSTS.
ENGRAM_ENVIRONMENT=dev
ENGRAM_DEBUG=false
ENGRAM_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
ENGRAM_LOG_LEVEL=INFO
ENGRAM_CELERY_BROKER_URL=amqp://engram:engram@rabbitmq:5672/engram
# Optional RabbitMQ node identity; these examples are the Compose defaults.
# ENGRAM_RABBITMQ_HOSTNAME=rabbitmq
# ENGRAM_RABBITMQ_NODENAME=rabbit@rabbitmq
# D2 must set both values to the exact recorded identity. The nodename suffix and
# hostname must agree; never guess either value independently.
ENGRAM_CELERY_RESULT_BACKEND=redis://redis:6379/1
ENGRAM_BOOTSTRAP_ADMIN_USERNAME=admin
ENGRAM_BOOTSTRAP_ADMIN_PASSWORD=
ENGRAM_BOOTSTRAP_ORG_SLUG=default
ENGRAM_BOOTSTRAP_PROJECT_SLUG=default
ENGRAM_BOOTSTRAP_TEAM_SLUG=default
# Minutes of inactivity before an ACTIVE agent session is force-ended and distilled
ENGRAM_SESSION_IDLE_TIMEOUT_MINUTES=30
ENGRAM_PROVIDER_HTTP_TIMEOUT=60
ENGRAM_EMBEDDING_HTTP_TIMEOUT=30
ENGRAM_DISTILL_CHUNK_CHAR_BUDGET=40000
# Ceiling on the per-chunk char budget derived from the model's context window.
# Independent of ENGRAM_PROVIDER_HTTP_TIMEOUT: raising the timeout must never grow chunks.
ENGRAM_DISTILL_CHUNK_CHAR_CEILING=120000
ENGRAM_DISTILL_MAX_CHUNKS=8
ENGRAM_DISTILL_REDUCE_TARGET=12
ENGRAM_DISTILL_SOFT_TIME_LIMIT=600
ENGRAM_DISTILL_TIME_LIMIT=660
# Operational envelope: ENGRAM_DISTILL_SOFT_TIME_LIMIT must be >=
# (ENGRAM_DISTILL_MAX_CHUNKS + 2) * ENGRAM_PROVIDER_HTTP_TIMEOUT, so the soft time
# limit always outlasts every chunk's provider call plus reduce/embed overhead.
# Emit ops counter gauges as global aggregates without per-tenant labels.
ENGRAM_OPS_GLOBAL_COUNTERS=true
# Days a proposed candidate stays in the review queue before TTL-drain archives it.
ENGRAM_CANDIDATE_REVIEW_TTL_DAYS=14
# Max candidates drained per TTL sweep batch.
ENGRAM_CANDIDATE_TTL_BATCH=500
# Minimum observation content length (chars) before a realtime candidate is generated.
ENGRAM_REALTIME_MIN_CONTENT_CHARS=80
